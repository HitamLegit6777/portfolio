---
import { profile, stats } from '../data/portfolio.ts';
---

<section class="hero" id="top">
  <div class="container hero-grid">
    <div class="hero-left">
      <span class="status">
        <span class="pulse"></span> {profile.status}
      </span>

      <h1 class="hero-title">
        Hi, gue <span class="hl hl-yellow">{profile.name}</span>
        <br />
        a.k.a <span class="hl hl-pink">{profile.handle}</span>
        <span class="wave">👋</span>
      </h1>

      <div class="role-line">
        <span class="r-arrow">▶</span>
        <span class="role" id="role">{profile.roles[0]}</span><span class="cursor">_</span>
      </div>

      <p class="hero-sub">{profile.tagline}</p>

      <div class="hero-cta">
        <a href="#work" class="btn">
          Lihat project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#contact" class="btn btn-outline">Hubungi saya</a>
      </div>

      <div class="hero-socials">
        {profile.socials.map((s) => (
          <a href={s.href} class="social" target="_blank" rel="noopener">
            <span class="s-letter">{s.letter}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="hero-right">
      <div class="avatar-card">
        <div class="avatar-stripe">PORTRAIT.JPG</div>
        <div class="avatar-box">
          <div class="avatar-emoji">🧑‍💻</div>
          <div class="avatar-glitch">{profile.handle}</div>
        </div>
        <div class="avatar-foot">
          <span>📍 {profile.location}</span>
          <span class="dot">●</span>
          <span>v3.0</span>
        </div>
        <span class="badge-star b1">★</span>
        <span class="badge-star b2">✦</span>
        <span class="badge-sticker bs1">VIBE<br />CODER</span>
        <span class="badge-sticker bs2">SINCE<br />2022</span>
      </div>
    </div>
  </div>

  <div class="container stats-strip reveal">
    {stats.map((s) => (
      <div class="stat">
        <span class="stat-value">{s.value}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    padding: 70px 0 40px;
    position: relative;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 16px;
    background: var(--green);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    transform: rotate(-1.5deg);
  }
  .pulse {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink);
    animation: blink 1.2s infinite;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 84px);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 26px 0 22px;
    text-transform: uppercase;
  }
  .hl {
    display: inline-block;
    padding: 0 10px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transform: rotate(-1.5deg);
  }
  .hl-yellow { background: var(--yellow); }
  .hl-pink { background: var(--pink); }
  .wave {
    display: inline-block;
    animation: wobble 2s ease-in-out infinite;
    transform-origin: 70% 70%;
  }

  .role-line {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-family: var(--font-mono);
    font-size: clamp(18px, 2.4vw, 26px);
    font-weight: 700;
  }
  .r-arrow { color: var(--pink); }
  .role { color: var(--ink); }
  .cursor {
    color: var(--blue);
    animation: blink 1s steps(1) infinite;
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 540px;
    margin-bottom: 32px;
  }

  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 34px;
  }

  .hero-socials {
    display: flex;
    gap: 12px;
  }
  .social {
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s var(--ease), background 0.2s;
  }
  .social:hover {
    transform: translate(-3px, -3px) rotate(-6deg);
    background: var(--yellow);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .s-letter {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
  }

  /* Avatar card */
  .hero-right {
    perspective: 1200px;
  }
  .avatar-card {
    position: relative;
    background: #fff;
    border: var(--border-thick);
    box-shadow: var(--shadow-lg);
    transform: rotate(2.5deg);
    transition: transform 0.4s var(--ease);
  }
  .avatar-card:hover {
    transform: rotate(-1deg);
  }

  .avatar-stripe {
    background: var(--ink);
    color: var(--yellow);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 8px 16px;
    border-bottom: var(--border);
  }

  .avatar-box {
    position: relative;
    height: 340px;
    background:
      repeating-linear-gradient(45deg, var(--purple) 0 18px, #fff 18px 20px),
      var(--purple);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .avatar-emoji {
    font-size: 130px;
    filter: drop-shadow(6px 6px 0 var(--ink));
    z-index: 1;
  }
  .avatar-glitch {
    position: absolute;
    bottom: 14px;
    left: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 30px;
    background: var(--ink);
    color: var(--green);
    padding: 4px 12px;
    border: 3px solid var(--ink);
  }

  .avatar-foot {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-top: var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
  }
  .avatar-foot .dot {
    color: var(--green);
  }

  .badge-star {
    position: absolute;
    font-size: 26px;
    animation: spin 8s linear infinite;
  }
  .b1 { top: -22px; right: 30px; color: var(--yellow); -webkit-text-stroke: 2px var(--ink); }
  .b2 { bottom: 80px; left: -26px; color: var(--pink); -webkit-text-stroke: 2px var(--ink); animation-direction: reverse; }

  .badge-sticker {
    position: absolute;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    display: grid;
    place-items: center;
    text-align: center;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    line-height: 1.3;
  }
  .bs1 {
    top: 70px;
    right: -34px;
    background: var(--orange);
    transform: rotate(12deg);
  }
  .bs2 {
    bottom: 40px;
    right: -30px;
    background: var(--green);
    transform: rotate(-10deg);
  }

  /* Stats strip */
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 70px;
    border: var(--border);
    box-shadow: var(--shadow);
  }
  .stat {
    padding: 28px 22px;
    background: #fff;
    border-right: var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat:last-child { border-right: none; }
  .stat:nth-child(1) { background: var(--yellow); }
  .stat:nth-child(2) { background: #fff; }
  .stat:nth-child(3) { background: var(--pink); }
  .stat:nth-child(4) { background: var(--blue); color: #fff; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(34px, 4.5vw, 52px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; gap: 56px; }
    .bs1, .bs2 { display: none; }
    .avatar-box { height: 280px; }
  }
  @media (max-width: 620px) {
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: var(--border); }
  }
</style>

<script>
  const data = document.getElementById('role');
  if (data) {
    const list = [
      'Full-Stack Developer',
      'UI/UX Enthusiast',
      'Open Source Contributor',
      'Problem Solver',
      'Tech Blogger',
      'Vibe Coder',
    ];
    let i = 0;
    setInterval(() => {
      i = (i + 1) % list.length;
      data.textContent = list[i];
    }, 2200);
  }
</script>
