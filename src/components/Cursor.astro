---
// Premium spotlight cursor + magnetic buttons (desktop / fine-pointer only)
---

<div class="cursor-root" aria-hidden="true">
  <div class="cursor-spot" id="cursorSpot"></div>
</div>

<style>
  .cursor-root {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    display: none;
  }
  .cursor-spot {
    position: fixed;
    top: 0;
    left: 0;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle,
      rgba(168, 85, 247, 0.08),
      rgba(34, 211, 238, 0.04) 40%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out);
    will-change: transform;
    mix-blend-mode: screen;
  }
  .cursor-root.on { display: block; }
  .cursor-spot.on { opacity: 1; }

  /* Magnetic button hover lift */
  .magnetic {
    transition: transform 0.3s var(--ease-out);
    will-change: transform;
  }

  @media (hover: none), (max-width: 899px) {
    .cursor-root { display: none !important; }
  }
</style>

<script>
  const root = document.querySelector('.cursor-root');
  const spot = document.getElementById('cursorSpot');
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  if (root && spot && fine) {
    root.classList.add('on');
    let tx = window.innerWidth / 2;
    let ty = window.innerHeight / 2;
    let cx = tx;
    let cy = ty;

    window.addEventListener('pointermove', (e) => {
      tx = e.clientX;
      ty = e.clientY;
      spot.classList.add('on');
    });
    window.addEventListener('pointerleave', () => spot.classList.remove('on'));

    const raf = () => {
      cx += (tx - cx) * 0.12;
      cy += (ty - cy) * 0.12;
      spot.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
      requestAnimationFrame(raf);
    };
    raf();

    // Magnetic effect on buttons & nav links
    const magnetic = document.querySelectorAll<HTMLElement>(
      '.btn-primary, .nav-cta, .plan-cta, .brand, .card-link'
    );
    magnetic.forEach((el) => {
      el.classList.add('magnetic');
      const strength = 18;
      el.addEventListener('pointermove', (e) => {
        const r = el.getBoundingClientRect();
        const x = e.clientX - (r.left + r.width / 2);
        const y = e.clientY - (r.top + r.height / 2);
        el.style.transform = `translate(${(x / r.width) * strength}px, ${(y / r.height) * strength}px)`;
      });
      el.addEventListener('pointerleave', () => {
        el.style.transform = '';
      });
    });
  }
</script>
