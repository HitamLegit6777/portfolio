---
const faqs = [
  {
    q: 'Do I need to know how to code?',
    a: 'No. Nebula is designed to be steered by anyone with a clear idea. Engineers get full code access and terminal control; everyone else gets the canvas and natural-language steering.',
  },
  {
    q: 'Can I bring my own codebase?',
    a: 'Yes. Connect a GitHub or GitLab repo and Nebula will map your architecture, then agents work directly against your branches with reviewable pull requests.',
  },
  {
    q: 'How do the agents stay on-task?',
    a: 'A planner agent maintains a living spec. Every change is checked against it, plus typed tests, linters, and a QA agent. You can lock critical files and require approval.',
  },
  {
    q: 'Where does my data live?',
    a: 'Your code and prompts are encrypted at rest and in transit, isolated per workspace, and never used to train shared models. Enterprise plans add dedicated regions and BYOK.',
  },
];
---

<section class="section faq">
  <div class="container faq-grid">
    <div class="faq-side reveal">
      <span class="eyebrow"><span class="dot"></span> FAQ</span>
      <h2 class="section-title" style="text-align:left">Questions, <span class="grad-text">answered</span></h2>
      <p class="section-sub" style="text-align:left">Still curious? Our team replies in minutes during business hours.</p>
      <a href="#cta" class="btn btn-ghost">Chat with us</a>
    </div>

    <div class="faq-list reveal" data-stagger="true">
      {
        faqs.map((f) => (
          <details class="faq-item">
            <summary>
              <span>{f.q}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 64px;
    align-items: start;
  }
  .faq-side .btn { margin-top: 24px; }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
  }
  .faq-item[open] {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 22px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.35s var(--ease-out), background 0.3s;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background: var(--grad-violet);
    color: #fff;
    border-color: transparent;
  }
  .faq-a {
    padding: 0 22px 20px;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
    max-width: 60ch;
  }

  @media (max-width: 880px) {
    .faq-grid { grid-template-columns: 1fr; gap: 36px; }
    .section-title { text-align: center !important; }
    .faq-side .section-sub { text-align: center !important; }
    .faq-side { text-align: center; }
    .faq-side .btn { margin: 24px auto 0; }
  }
</style>
