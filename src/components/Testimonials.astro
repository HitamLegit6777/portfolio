---
const testimonials = [
  {
    quote: 'We shipped our v1 in a weekend. What used to take a quarter now takes an afternoon. Nebula is unfair leverage.',
    name: 'Maya Chen',
    role: 'Founder, Lumen Labs',
    accent: '#a78bfa',
  },
  {
    quote: 'The agent canvas feels like pair-programming with a senior team that never sleeps. Our PR throughput tripled.',
    name: 'Diego Ramos',
    role: 'Staff Eng, Northwind',
    accent: '#22d3ee',
  },
  {
    quote: 'I stopped writing boilerplate. I review, steer, and ship. This is the workflow I always wanted.',
    name: 'Priya Nair',
    role: 'CTO, Cartograph',
    accent: '#d946ef',
  },
  {
    quote: 'Onboarding non-engineers onto the canvas changed how our whole company ships. Designers push to prod now.',
    name: 'Tom Bauer',
    role: 'Head of Product, Wavelength',
    accent: '#34d399',
  },
  {
    quote: 'Edge deploys under two seconds, with rollback. Our incident response has never been this calm.',
    name: 'Sofia Ibarra',
    role: 'SRE Lead, Helios',
    accent: '#fbbf24',
  },
  {
    quote: 'Observability that actually explains itself. I can trace a bug from prompt to production in seconds.',
    name: 'Kwame Osei',
    role: 'Eng Manager, Driftwood',
    accent: '#a78bfa',
  },
];
---

<section class="section testimonials" id="customers">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow"><span class="dot"></span> Loved by builders</span>
      <h2 class="section-title">Teams ship <span class="grad-text">differently</span> with Nebula</h2>
      <p class="section-sub">From solo founders to platform teams of 500 — here's what they say after their first week.</p>
    </div>
  </div>

  <div class="t-wrap reveal">
    <div class="t-track t-track-1">
      {[...testimonials, ...testimonials].map((t) => (
        <figure class="t-card">
          <svg class="t-quote" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style={`color:${t.accent}`}>
            <path d="M7 11H4a1 1 0 0 1-1-1V7a3 3 0 0 1 3-3 1 1 0 0 1 1 1v5a3 3 0 0 1-3 3M18 11h-3a1 1 0 0 1-1-1V7a3 3 0 0 1 3-3 1 1 0 0 1 1 1v5a3 3 0 0 1-3 3" />
          </svg>
          <blockquote class="t-quote-text">{t.quote}</blockquote>
          <figcaption class="t-author">
            <span class="t-avatar" style={`background:linear-gradient(135deg, ${t.accent}, ${t.accent}66)`}></span>
            <span>
              <strong>{t.name}</strong>
              <em>{t.role}</em>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials { padding-bottom: 80px; }

  .t-wrap {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .t-track {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: marquee 48s linear infinite;
  }
  .t-wrap:hover .t-track {
    animation-play-state: paused;
  }

  .t-card {
    width: 360px;
    flex-shrink: 0;
    padding: 28px;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface), rgba(255, 255, 255, 0.015));
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition: border-color 0.4s, transform 0.4s var(--ease-out);
  }
  .t-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
  }

  .t-quote-text {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text);
    flex: 1;
  }

  .t-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .t-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .t-author strong {
    display: block;
    font-size: 14.5px;
    font-weight: 600;
  }
  .t-author em {
    font-style: normal;
    font-size: 13px;
    color: var(--text-dim);
  }
</style>
