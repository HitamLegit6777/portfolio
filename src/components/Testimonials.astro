---
import { testimonials } from '../data/portfolio.ts';
---

<section class="section testimonials" id="testimonials">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-kicker">// Word on the street</span>
      <h2 class="section-title">
        Kata<br />
        <span class="hl-inline" style="background:var(--pink)">mereka</span>
      </h2>
    </div>
  </div>

  <div class="t-marquee reveal">
    <div class="t-track">
      {[...testimonials, ...testimonials].map((t) => (
        <figure class="t-card" style={`--c:${t.color}`}>
          <div class="t-stars">★★★★★</div>
          <blockquote class="t-quote">"{t.quote}"</blockquote>
          <figcaption class="t-who">
            <span class="t-avatar">{t.name[0]}</span>
            <span>
              <strong>{t.name}</strong>
              <em>{t.role}</em>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .hl-inline {
    display: inline-block;
    padding: 0 12px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transform: rotate(-2deg);
  }

  .t-marquee {
    overflow: hidden;
    padding: 10px 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .t-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: marquee 50s linear infinite;
  }
  .t-marquee:hover .t-track {
    animation-play-state: paused;
  }

  .t-card {
    width: 360px;
    flex-shrink: 0;
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow);
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .t-stars {
    color: var(--c);
    font-size: 20px;
    letter-spacing: 2px;
    -webkit-text-stroke: 1px var(--ink);
  }
  .t-quote {
    font-size: 16px;
    line-height: 1.6;
    flex: 1;
  }
  .t-who {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 3px solid var(--ink);
    padding-top: 16px;
  }
  .t-avatar {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    background: var(--c);
    border: 3px solid var(--ink);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    transform: rotate(-5deg);
  }
  .t-who strong {
    display: block;
    font-size: 15px;
    font-weight: 700;
  }
  .t-who em {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }
</style>
