---
const steps = [
  {
    n: '01',
    title: 'Describe your vision',
    desc: 'Type a sentence, drop a spec, or paste a Figma link. Nebula parses intent and builds a living plan.',
    tag: 'Input',
  },
  {
    n: '02',
    title: 'Agents take the wheel',
    desc: 'Specialised agents design the system, write production code, and wire up infra — reviewing each other as they go.',
    tag: 'Build',
  },
  {
    n: '03',
    title: 'Preview & steer',
    desc: 'Watch changes land live on the canvas. Redirect, branch, or roll back with a single click.',
    tag: 'Iterate',
  },
  {
    n: '04',
    title: 'Ship to the edge',
    desc: 'One command deploys to 300+ edge locations with rollback, analytics, and observability baked in.',
    tag: 'Deploy',
  },
];

const stats = [
  { value: '1.2s', label: 'Median deploy time', sub: 'across 300+ regions' },
  { value: '99.99%', label: 'Uptime SLA', sub: 'on enterprise plans' },
  { value: '12M+', label: 'Agents runs / day', sub: 'and climbing fast' },
  { value: '4.2x', label: 'Faster ship cycle', sub: 'vs. traditional stack' },
];
---

<section class="section workflow" id="workflow">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow"><span class="dot"></span> How it works</span>
      <h2 class="section-title">From prompt to production in <span class="grad-text">four moves</span></h2>
      <p class="section-sub">No glue code, no context-switching, no yak shaving. Just a clean path from idea to orbit.</p>
    </div>

    <div class="steps reveal" data-stagger="true">
      <div class="steps-line" aria-hidden="true"></div>
      {
        steps.map((s) => (
          <article class="step">
            <div class="step-num">{s.n}</div>
            <span class="step-tag">{s.tag}</span>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </article>
        ))
      }
    </div>

    <div class="stats reveal">
      {
        stats.map((s) => (
          <div class="stat">
            <span class="stat-value grad-text">{s.value}</span>
            <span class="stat-label">{s.label}</span>
            <span class="stat-sub">{s.sub}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 96px;
  }

  .steps-line {
    position: absolute;
    top: 32px;
    left: 8%;
    right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-strong) 12%, var(--border-strong) 88%, transparent);
  }

  .step {
    position: relative;
    padding: 24px;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    transition: transform 0.4s var(--ease-out), border-color 0.4s, background 0.4s;
  }
  .step:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .step-num {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 22px;
    background: var(--bg-1);
    border: 1px solid var(--border-strong);
    color: var(--text);
    position: relative;
    z-index: 1;
  }
  .step:hover .step-num {
    background: var(--grad-violet);
    border-color: transparent;
    box-shadow: 0 0 30px -5px var(--violet);
    color: #fff;
  }

  .step-tag {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fuchsia);
  }
  .step-title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 8px 0 10px;
  }
  .step-desc {
    font-size: 14.5px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .stat {
    padding: 36px 28px;
    background: var(--bg-1);
    text-align: center;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    display: block;
    margin-bottom: 12px;
  }
  .stat-label {
    display: block;
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 4px;
  }
  .stat-sub {
    display: block;
    font-size: 13px;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .steps, .stats { grid-template-columns: repeat(2, 1fr); }
    .steps-line { display: none; }
  }
  @media (max-width: 540px) {
    .steps, .stats { grid-template-columns: 1fr; }
  }
</style>
