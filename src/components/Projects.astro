---
import { projects } from '../data/portfolio.ts';
---

<section class="section work" id="work">
  <div class="container">
    <div class="section-head reveal" style="display:flex; align-items:end; justify-content:space-between; flex-wrap:wrap; gap:20px; width:100%; margin-bottom:48px">
      <div>
        <span class="section-kicker">// Selected work</span>
        <h2 class="section-title">
          Project<br />
          <span class="hl-inline" style="background:var(--blue); color:#fff">galeri</span>
        </h2>
      </div>
      <p class="work-note">Dari SMM panel yang handle ribuan transaksi, bot automation, sampe tools random yang dibuat iseng.</p>
    </div>

    <div class="proj-grid reveal" data-stagger="true">
      {projects.map((p, i) => (
        <article class={`proj ${p.featured ? 'featured' : ''}`} style={`--c:${p.color}`}>
          <div class="proj-top">
            <span class="proj-idx">#{String(i + 1).padStart(2, '0')}</span>
            {p.featured && <span class="proj-feat">★ Featured</span>}
          </div>

          <div class="proj-visual">
            <span class="proj-emoji">
              {['📱','🤖','📨','🔗','🎮','🛠️','🧾'][i % 7]}
            </span>
            <div class="proj-pattern"></div>
          </div>

          <div class="proj-body">
            <h3 class="proj-title">{p.title}</h3>
            <p class="proj-desc">{p.desc}</p>
            <div class="proj-tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="proj-links">
              {p.live && (
                <a href={p.live} class="plink live" target="_blank" rel="noopener">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Live
                </a>
              )}
              {p.code && (
                <a href={p.code} class="plink code" target="_blank" rel="noopener">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  Code
                </a>
              )}
              {!p.live && !p.code && <span class="plink none">Private client</span>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work-note {
    max-width: 340px;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    border-left: 4px solid var(--ink);
    padding-left: 14px;
  }
  .hl-inline {
    display: inline-block;
    padding: 0 12px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transform: rotate(-2deg);
  }

  .proj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .proj {
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .proj:hover {
    transform: translate(-5px, -5px);
    box-shadow: 13px 13px 0 var(--ink);
  }
  .proj.featured {
    grid-column: span 1;
  }
  .proj.featured .proj-visual {
    height: 160px;
  }

  .proj-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .proj-feat {
    color: var(--c);
  }

  .proj-visual {
    position: relative;
    height: 130px;
    background: var(--c);
    border-bottom: var(--border);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .proj-emoji {
    font-size: 60px;
    filter: drop-shadow(4px 4px 0 var(--ink));
    z-index: 1;
  }
  .proj-pattern {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.12) 0 14px,
      transparent 14px 28px
    );
  }

  .proj-body {
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .proj-title {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 10px;
  }
  .proj-desc {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 16px;
    flex: 1;
  }
  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
  }
  .tag {
    padding: 4px 10px;
    background: var(--paper);
    border: 2px solid var(--ink);
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 600;
  }
  .proj-links {
    display: flex;
    gap: 10px;
  }
  .plink {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 3px solid var(--ink);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    transition: all 0.2s var(--ease);
  }
  .plink.live {
    background: var(--ink);
    color: var(--paper);
  }
  .plink.live:hover {
    background: var(--c);
    color: var(--ink);
    transform: rotate(-2deg);
  }
  .plink.code {
    background: #fff;
    color: var(--ink);
  }
  .plink.code:hover {
    background: var(--c);
    transform: rotate(2deg);
  }
  .plink.none {
    background: var(--paper);
    color: var(--muted);
    cursor: default;
  }

  @media (max-width: 900px) {
    .proj-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .proj-grid { grid-template-columns: 1fr; }
  }
</style>
