---
import { profile } from '../data/portfolio.ts';
const links = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Skills', href: '#skills' },
  { label: 'Experience', href: '#experience' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contact', href: '#contact' },
];
---

<div class="topbar">
  <div class="marquee">
    <div class="marquee-track">
      {
        Array.from({ length: 2 }).map(() => (
          <span class="marquee-group">
            {profile.roles.map((r) => (
              <span class="m-item">{r} <i>★</i></span>
            ))}
          </span>
        ))
      }
    </div>
  </div>
</div>

<header class="nav" id="nav">
  <div class="container nav-inner">
    <a href="#top" class="brand">
      <span class="brand-mark">{profile.name[0]}</span>
      <span class="brand-text">{profile.name}<i>.dev</i></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href} class="nav-link">{l.label}</a>)}
    </nav>

    <div class="nav-actions">
      <a href="#contact" class="btn btn-ink nav-cta">Let's talk</a>
      <button class="burger" id="burger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    {links.map((l) => <a href={l.href} class="m-link">{l.label}</a>)}
    <a href="#contact" class="btn btn-ink m-cta">Let's talk</a>
  </div>
</header>

<style>
  .topbar {
    background: var(--ink);
    color: var(--paper);
    border-bottom: var(--border);
    overflow: hidden;
    padding: 9px 0;
  }
  .marquee {
    overflow: hidden;
    white-space: nowrap;
  }
  .marquee-track {
    display: inline-flex;
    width: max-content;
    animation: marquee 30s linear infinite;
  }
  .marquee-group {
    display: inline-flex;
    align-items: center;
  }
  .m-item {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0 22px;
    display: inline-flex;
    align-items: center;
    gap: 22px;
  }
  .m-item i {
    color: var(--yellow);
    font-style: normal;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--paper);
    border-bottom: var(--border);
  }
  .nav.scrolled {
    box-shadow: 0 6px 0 var(--ink);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    height: 74px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    background: var(--yellow);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    font-size: 22px;
    font-weight: 700;
    transform: rotate(-4deg);
    transition: transform 0.3s var(--ease);
  }
  .brand:hover .brand-mark {
    transform: rotate(4deg) scale(1.05);
  }
  .brand-text i {
    font-style: normal;
    color: var(--pink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-link {
    padding: 9px 16px;
    font-weight: 600;
    font-size: 15px;
    border: 3px solid transparent;
    transition: all 0.2s var(--ease);
  }
  .nav-link:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
    transform: rotate(-2deg);
  }

  .nav-cta {
    padding: 11px 20px;
    font-size: 14px;
    box-shadow: var(--shadow-sm);
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    border: 3px solid var(--ink);
    background: var(--pink);
  }
  .burger span {
    width: 24px;
    height: 3px;
    background: var(--ink);
    transition: transform 0.3s var(--ease), opacity 0.3s;
  }
  .burger.open span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .burger.open span:nth-child(2) {
    opacity: 0;
  }
  .burger.open span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 16px 22px 24px;
    border-bottom: var(--border);
    background: var(--paper);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease), padding 0.4s;
    padding-top: 0;
    padding-bottom: 0;
  }
  .mobile-menu.open {
    max-height: 520px;
    padding-top: 16px;
    padding-bottom: 24px;
  }
  .m-link {
    padding: 14px 12px;
    font-weight: 700;
    font-size: 18px;
    border: 3px solid var(--ink);
    background: #fff;
    text-transform: uppercase;
  }
  .m-cta {
    margin-top: 8px;
    width: 100%;
  }

  @media (max-width: 899px) {
    .nav-links {
      display: none;
    }
    .nav-cta {
      display: none;
    }
    .burger {
      display: flex;
    }
    .mobile-menu {
      display: flex;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobileMenu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  burger?.addEventListener('click', () => {
    const open = burger.classList.toggle('open');
    menu?.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
  });

  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      burger?.classList.remove('open');
      menu?.classList.remove('open');
    })
  );
</script>
