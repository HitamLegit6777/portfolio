---
import { blogs } from '../data/portfolio.ts';
---

<section class="section blog" id="blog">
  <div class="container">
    <div class="section-head reveal" style="display:flex; align-items:end; justify-content:space-between; flex-wrap:wrap; gap:20px; width:100%; margin-bottom:48px">
      <div>
        <span class="section-kicker">// From the blog</span>
        <h2 class="section-title">
          Tulisan<br />
          <span class="hl-inline" style="background:var(--purple); color:#fff">random</span>
        </h2>
      </div>
    </div>

    <div class="blog-grid reveal" data-stagger="true">
      {blogs.map((b, i) => (
        <article class="b-card" style={`--c:${b.color}`}>
          <div class="b-cover">
            <span class="b-emoji">{['📝','🤖','🔗','🤖','🎲','🚀'][i % 6]}</span>
            <span class="b-cat">{b.category}</span>
          </div>
          <div class="b-body">
            <div class="b-meta">
              <span>🕐 {b.read}</span>
              <span class="b-dot">●</span>
              <span>{b.date}</span>
            </div>
            <h3 class="b-title">{b.title}</h3>
            <p class="b-excerpt">{b.excerpt}</p>
            <a href={`/blog/${b.slug}`} class="b-link">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .hl-inline {
    display: inline-block;
    padding: 0 12px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transform: rotate(-2deg);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .b-card {
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .b-card:hover {
    transform: translate(-5px, -5px);
    box-shadow: 13px 13px 0 var(--ink);
  }

  .b-cover {
    position: relative;
    height: 130px;
    background: var(--c);
    border-bottom: var(--border);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .b-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      rgba(0, 0, 0, 0.1) 0 12px,
      transparent 12px 24px
    );
  }
  .b-emoji {
    font-size: 52px;
    filter: drop-shadow(3px 3px 0 var(--ink));
    z-index: 1;
  }
  .b-cat {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 1;
  }

  .b-body {
    padding: 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .b-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .b-dot { color: var(--c); }
  .b-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .b-excerpt {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 18px;
    flex: 1;
  }
  .b-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    color: var(--ink);
  }
  .b-link:hover {
    color: var(--c);
    gap: 10px;
  }

  @media (max-width: 900px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
