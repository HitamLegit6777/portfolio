---
const plans = [
  {
    name: 'Hobby',
    price: { m: 0, y: 0 },
    tagline: 'For tinkerers and side-projects.',
    features: ['3 active agents', '1 workspace', 'Community support', '100 agent runs / mo', 'Edge preview deploys'],
    cta: 'Start free',
    featured: false,
  },
  {
    name: 'Pro',
    price: { m: 24, y: 19 },
    tagline: 'For builders shipping to real users.',
    features: [
      'Unlimited agents',
      '10 workspaces',
      'Priority support',
      'Unlimited agent runs',
      'Production edge deploys',
      'Custom domains & SSL',
      'Full observability suite',
    ],
    cta: 'Start 14-day trial',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: { m: null, y: null },
    tagline: 'For teams that need control & scale.',
    features: ['Everything in Pro', 'SSO + SCIM', 'SOC 2 / GDPR', 'Dedicated regions', '99.99% uptime SLA', 'Solutions architect'],
    cta: 'Talk to sales',
    featured: false,
  },
];
---

<section class="section pricing" id="pricing">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow"><span class="dot"></span> Pricing</span>
      <h2 class="section-title">Simple pricing that <span class="grad-text">scales with you</span></h2>
      <p class="section-sub">Start free, upgrade when you ship. No usage gotchas, no per-seat surprises.</p>
    </div>

    <div class="bill-toggle reveal" role="tablist" aria-label="Billing period">
      <button class="bill-btn active" data-bill="m" role="tab" aria-selected="true">Monthly</button>
      <button class="bill-btn" data-bill="y" role="tab" aria-selected="false">
        Yearly <span class="bill-save">Save 20%</span>
      </button>
      <span class="bill-thumb" aria-hidden="true"></span>
    </div>

    <div class="plans reveal" data-stagger="true">
      {
        plans.map((p) => (
          <article class={`plan ${p.featured ? 'featured' : ''}`}>
            {p.featured && <span class="plan-badge">Most popular</span>}
            <h3 class="plan-name">{p.name}</h3>
            <p class="plan-tagline">{p.tagline}</p>
            <div class="plan-price">
              {p.price.m === null ? (
                <span class="price-custom">Custom</span>
              ) : (
                <>
                  <span class="price-currency">$</span>
                  <span class="price-amount" data-m={p.price.m} data-y={p.price.y}>{p.price.m}</span>
                  <span class="price-period">/mo</span>
                </>
              )}
            </div>
            <a href="#cta" class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'} plan-cta`}>{p.cta}</a>
            <ul class="plan-features">
              {p.features.map((f) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bill-toggle {
    position: relative;
    display: inline-flex;
    gap: 4px;
    margin: 0 auto 48px;
    padding: 5px;
    border-radius: 100px;
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    justify-content: center;
  }
  .bill-btn {
    position: relative;
    z-index: 1;
    padding: 9px 22px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.3s;
  }
  .bill-btn.active { color: #fff; }
  .bill-save {
    margin-left: 6px;
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 100px;
    background: rgba(52, 211, 153, 0.15);
    color: var(--emerald);
  }
  .bill-thumb {
    position: absolute;
    top: 5px;
    left: 5px;
    height: calc(100% - 10px);
    width: 96px;
    border-radius: 100px;
    background: var(--grad-violet);
    box-shadow: 0 4px 16px -4px var(--violet);
    transition: transform 0.45s var(--ease-out), width 0.45s var(--ease-out);
    z-index: 0;
  }

  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }

  .plan {
    position: relative;
    padding: 32px 28px;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface), rgba(255, 255, 255, 0.015));
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .plan.featured {
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.12), rgba(217, 70, 239, 0.04));
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: var(--shadow-glow);
    transform: scale(1.04);
    z-index: 1;
  }

  .plan-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    padding: 5px 14px;
    border-radius: 100px;
    background: var(--grad-violet);
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    box-shadow: 0 6px 20px -4px var(--violet);
  }

  .plan-name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
  }
  .plan-tagline {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 6px;
    min-height: 40px;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin: 22px 0 26px;
    font-family: var(--font-display);
  }
  .price-currency { font-size: 22px; font-weight: 600; color: var(--text-muted); }
  .price-amount { font-size: 56px; font-weight: 700; letter-spacing: -0.04em; line-height: 1; }
  .price-period { font-size: 16px; color: var(--text-dim); font-weight: 500; }
  .price-custom { font-size: 48px; font-weight: 700; letter-spacing: -0.03em; }

  .plan-cta {
    width: 100%;
    margin-bottom: 28px;
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .plan-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14.5px;
    color: var(--text-muted);
  }
  .plan-features svg {
    color: var(--emerald);
    flex-shrink: 0;
  }
  .plan.featured .plan-features svg { color: var(--violet); }

  @media (max-width: 900px) {
    .plans { grid-template-columns: 1fr; max-width: 440px; margin: 0 auto; }
    .plan.featured { transform: none; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.bill-btn');
  const thumb = document.querySelector<HTMLElement>('.bill-thumb');
  const amounts = document.querySelectorAll<HTMLElement>('.price-amount');

  const moveThumb = (btn: HTMLElement) => {
    if (!thumb) return;
    const rect = btn.getBoundingClientRect();
    const parent = btn.parentElement!.getBoundingClientRect();
    thumb.style.width = `${rect.width}px`;
    thumb.style.transform = `translateX(${rect.left - parent.left - 5}px)`;
  };

  const setBill = (mode: 'm' | 'y') => {
    buttons.forEach((b) => {
      const active = b.dataset.bill === mode;
      b.classList.toggle('active', active);
      b.setAttribute('aria-selected', String(active));
      if (active) moveThumb(b);
    });
    amounts.forEach((el) => {
      const v = el.dataset[mode];
      if (v != null) el.textContent = v;
    });
  };

  buttons.forEach((b) =>
    b.addEventListener('click', () => setBill(b.dataset.bill as 'm' | 'y'))
  );
  window.addEventListener('load', () => {
    const active = document.querySelector('.bill-btn.active') as HTMLElement | null;
    if (active) moveThumb(active);
  });
  window.addEventListener('resize', () => {
    const active = document.querySelector('.bill-btn.active') as HTMLElement | null;
    if (active) moveThumb(active);
  });
</script>
