---
import { profile } from '../data/portfolio.ts';
const year = new Date().getFullYear();
const nav = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Skills', href: '#skills' },
  { label: 'Experience', href: '#experience' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="footer">
  <div class="big-band">
    <div class="container band-inner">
      <span class="band-text">LET'S</span>
      <span class="band-text band-alt">BUILD</span>
      <span class="band-text">SOMETHING</span>
      <span class="band-text band-alt">TOGETHER</span>
    </div>
  </div>

  <div class="container footer-grid">
    <div class="f-brand">
      <a href="#top" class="brand">
        <span class="brand-mark">{profile.name[0]}</span>
        <span class="brand-text">{profile.name}<i>.dev</i></span>
      </a>
      <p class="f-tag">{profile.tagline}</p>
      <div class="f-socials">
        {profile.socials.map((s) => (
          <a href={s.href} class="fs-link" target="_blank" rel="noopener" aria-label={s.label}>
            {s.letter}
          </a>
        ))}
      </div>
    </div>

    <div class="f-nav">
      <h4>Navigate</h4>
      <ul>
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </div>

    <div class="f-contact">
      <h4>Contact</h4>
      <a href={`mailto:${profile.email}`} class="f-mail">{profile.email}</a>
      <p class="f-loc">{profile.location}</p>
      <a href="#contact" class="btn btn-pink f-cta">Start a project</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {profile.name} ({profile.handle}). Built with Astro & brute force.</p>
    <p class="fb-right">Made with ☕ + 🤖 in Indonesia</p>
  </div>
</footer>

<style>
  .big-band {
    background: var(--ink);
    color: var(--paper);
    border-top: var(--border);
    border-bottom: var(--border);
    padding: 18px 0;
    overflow: hidden;
  }
  .band-inner {
    display: flex;
    gap: 40px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 5vw, 56px);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    line-height: 1;
  }
  .band-text {
    display: inline-block;
  }
  .band-alt {
    color: var(--yellow);
    transform: rotate(-3deg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 48px;
    padding: 64px 22px 40px;
  }

  .f-brand .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    margin-bottom: 18px;
  }
  .f-brand .brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    background: var(--yellow);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    transform: rotate(-4deg);
  }
  .f-brand .brand-text i {
    font-style: normal;
    color: var(--pink);
  }
  .f-tag {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 38ch;
    margin-bottom: 22px;
  }
  .f-socials {
    display: flex;
    gap: 10px;
  }
  .fs-link {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-display);
    font-weight: 700;
    transition: all 0.2s var(--ease);
  }
  .fs-link:hover {
    background: var(--pink);
    transform: translate(-3px, -3px) rotate(-6deg);
    box-shadow: 8px 8px 0 var(--ink);
  }

  .f-nav h4,
  .f-contact h4 {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 18px;
    padding-bottom: 10px;
    border-bottom: 3px solid var(--ink);
  }
  .f-nav ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .f-nav a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    transition: all 0.2s var(--ease);
    display: inline-block;
  }
  .f-nav a:hover {
    color: var(--pink);
    transform: translateX(6px) rotate(-2deg);
  }

  .f-mail {
    display: block;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 6px;
    word-break: break-all;
  }
  .f-mail:hover {
    text-decoration: underline;
  }
  .f-loc {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 22px;
  }
  .f-cta {
    box-shadow: var(--shadow-sm);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding: 22px 22px 36px;
    border-top: 3px solid var(--ink);
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .f-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; gap: 36px; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
</style>
