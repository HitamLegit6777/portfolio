---
const footerCols = [
  {
    title: 'Product',
    links: ['Features', 'Workflow', 'Pricing', 'Changelog', 'Roadmap', 'Status'],
  },
  {
    title: 'Company',
    links: ['About', 'Blog', 'Careers', 'Press kit', 'Contact'],
  },
  {
    title: 'Resources',
    links: ['Docs', 'API reference', 'Templates', 'Community', 'Guides'],
  },
  {
    title: 'Legal',
    links: ['Privacy', 'Terms', 'Security', 'DPA', 'SOC 2'],
  },
];
const year = new Date().getFullYear();
---

<section class="cta" id="cta">
  <div class="container">
    <div class="cta-card reveal">
      <div class="cta-bg" aria-hidden="true"></div>
      <span class="eyebrow"><span class="dot"></span> Start in seconds</span>
      <h2 class="cta-title">Your next product is one <span class="grad-text">sentence away</span></h2>
      <p class="cta-sub">Join 28,000+ builders shipping with Nebula. Free to start, no card required.</p>
      <form class="cta-form" onsubmit="return false">
        <input type="email" placeholder="you@company.com" aria-label="Email" required />
        <button type="submit" class="btn btn-primary">
          Get started
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>
      <p class="cta-note">14-day Pro trial · Cancel anytime</p>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="#top" class="brand">
        <span class="brand-mark">
          <svg viewBox="0 0 32 32" width="26" height="26">
            <defs>
              <linearGradient id="fg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#a78bfa" />
                <stop offset="0.5" stop-color="#d946ef" />
                <stop offset="1" stop-color="#22d3ee" />
              </linearGradient>
            </defs>
            <path d="M16 4c1.9 4.8 5.2 8.1 10 10-4.8 1.9-8.1 5.2-10 10-1.9-4.8-5.2-8.1-10-10C10.8 12.1 14.1 8.8 16 4z" fill="url(#fg)"></path>
          </svg>
        </span>
        <span class="brand-name">Nebula</span>
      </a>
      <p class="footer-tag">The AI-native workspace for building software at the speed of thought.</p>
      <div class="socials">
        {['GitHub', 'X', 'Discord', 'LinkedIn'].map((s) => (
          <a href="#" class="social" aria-label={s}>
            <span class="social-letter">{s[0]}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="footer-cols">
      {
        footerCols.map((col) => (
          <div class="footer-col">
            <h4>{col.title}</h4>
            <ul>
              {col.links.map((l) => <li><a href="#">{l}</a></li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} Nebula Labs, Inc. All systems nominal.</p>
    <div class="region">
      <span class="region-dot"></span> All regions · <a href="#">Change</a>
    </div>
  </div>
</footer>

<style>
  .cta { padding: 40px 0 120px; }

  .cta-card {
    position: relative;
    text-align: center;
    padding: 80px 24px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-strong);
    background: linear-gradient(180deg, rgba(20, 20, 34, 0.9), rgba(11, 11, 20, 0.95));
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 0%, rgba(139, 92, 246, 0.25), transparent 50%),
      radial-gradient(circle at 70% 100%, rgba(34, 211, 238, 0.18), transparent 50%);
    pointer-events: none;
  }

  .cta-card > * { position: relative; z-index: 1; }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 22px 0 16px;
  }
  .cta-sub {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto 36px;
  }

  .cta-form {
    display: flex;
    gap: 10px;
    max-width: 460px;
    margin: 0 auto 16px;
    padding: 6px;
    border-radius: 100px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    backdrop-filter: blur(12px);
  }
  .cta-form input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    padding: 0 18px;
    color: var(--text);
    font-size: 15px;
    font-family: inherit;
  }
  .cta-form input::placeholder { color: var(--text-dim); }
  .cta-form .btn { flex-shrink: 0; }

  .cta-note {
    font-size: 13px;
    color: var(--text-dim);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--border);
    padding: 72px 0 32px;
    position: relative;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr;
    gap: 56px;
    margin-bottom: 56px;
  }

  .footer-brand .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    margin-bottom: 18px;
  }
  .footer-tag {
    color: var(--text-muted);
    font-size: 14.5px;
    line-height: 1.6;
    max-width: 34ch;
    margin-bottom: 24px;
  }

  .socials { display: flex; gap: 10px; }
  .social {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: all 0.3s var(--ease-out);
  }
  .social:hover {
    background: var(--grad-violet);
    color: #fff;
    border-color: transparent;
    transform: translateY(-2px);
  }
  .social-letter { font-weight: 700; font-size: 14px; font-family: var(--font-display); }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .footer-col h4 {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .footer-col ul { display: flex; flex-direction: column; gap: 11px; }
  .footer-col a {
    font-size: 14.5px;
    color: var(--text-muted);
    transition: color 0.25s;
  }
  .footer-col a:hover { color: var(--text); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    font-size: 13.5px;
    color: var(--text-dim);
  }
  .region { display: flex; align-items: center; gap: 8px; }
  .region-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--emerald);
    box-shadow: 0 0 8px var(--emerald);
  }
  .region a { color: var(--text-muted); }

  @media (max-width: 880px) {
    .footer-grid { grid-template-columns: 1fr; gap: 40px; }
    .footer-cols { grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .cta-form { flex-direction: column; border-radius: var(--radius); padding: 12px; }
    .cta-form input { padding: 12px 14px; }
    .cta-form .btn { width: 100%; }
  }
  @media (max-width: 540px) {
    .footer-bottom { flex-direction: column; gap: 10px; text-align: center; }
  }
</style>
